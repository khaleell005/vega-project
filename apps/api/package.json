{
  "name": "global-rate-limiter",
  "version": "1.0.0",
  "description": "Global Rate Limiter as a Service - Phases 1-5 (core limiter, Postgres logging, analytics, dashboard, tests)",
  "main": "src/server.ts",
  "type": "commonjs",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "migrate": "tsx src/db/migrate.ts",
    "test": "jest --runInBand --forceExit",
    "loadtest": "node test/load-test.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "opossum": "^8.1.4",
    "pg": "^8.12.0",
    "prisma": "^7.8.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/express": "^5.0.6",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^26.1.1",
    "@types/opossum": "^8.1.9",
    "@types/pg": "^8.20.0",
    "autocannon": "^7.15.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
